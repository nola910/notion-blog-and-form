---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "PMH Emergency Department Portal", 
  description = "Internal portal for PMH emergency physicians, APCs, and nurses to access department resources and provide feedback to the Medical Director."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Optimization -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 font-sans selection:bg-teal-500/30 selection:text-teal-200 overflow-x-hidden antialiased">
    <!-- Background subtle ambient lights -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-teal-500/10 blur-[128px]"></div>
      <div class="absolute top-1/2 -left-40 w-96 h-96 rounded-full bg-indigo-500/5 blur-[128px]"></div>
    </div>

    <!-- Sticky Navigation Header -->
    <header class="sticky top-0 z-40 w-full border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md transition-all duration-300">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo and Brand -->
        <a href="/" class="flex items-center gap-2.5 group transition-transform duration-200 hover:scale-[1.01]" id="nav-brand">
          <div class="relative flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-tr from-teal-500 to-indigo-600 shadow-md shadow-teal-500/20">
            <!-- Pulse Heartbeat Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-5 w-5 text-white animate-pulse">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-display font-bold leading-none text-white tracking-wide text-lg">PMH Emergency</span>
            <span class="text-[10px] font-medium uppercase tracking-widest text-teal-400">Department Portal</span>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <nav class="flex items-center gap-1 sm:gap-2" id="main-nav">
          <a 
            href="/" 
            class="rounded-lg px-4 py-2 text-sm font-medium transition-all duration-200 hover:bg-slate-900 hover:text-white"
            id="nav-link-home"
          >
            Dashboard
          </a>
          <a 
            href="/forms" 
            class="rounded-lg px-4 py-2 text-sm font-medium transition-all duration-200 hover:bg-slate-900 hover:text-white"
            id="nav-link-feedback"
          >
            Staff Feedback
          </a>
          
          <div class="ml-4 h-6 w-[1px] bg-slate-800 hidden md:block"></div>
          
          <div class="hidden md:flex items-center gap-2 ml-4">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-xs font-semibold text-slate-400">Medical Director Portal Connected</span>
          </div>
        </nav>
      </div>
    </header>

    <!-- Main Content Container -->
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-900 bg-slate-950 py-8 mt-16 text-center text-sm text-slate-500">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p>© {new Date().getFullYear()} PMH Emergency Department. Internal Use Only.</p>
          <div class="flex items-center gap-4 text-xs font-medium text-slate-400">
            <span>ED Admin: (555) 123-4567</span>
            <span>•</span>
            <span>Medical Director: Dr. TC</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Highlight active link script -->
    <script>
      const currentPath = window.location.pathname;
      const homeLink = document.getElementById('nav-link-home');
      const feedbackLink = document.getElementById('nav-link-feedback');
      
      if (currentPath === '/' || currentPath === '/index.html') {
        homeLink?.classList.add('bg-teal-500/10', 'text-teal-400', 'hover:text-teal-300');
        homeLink?.classList.remove('text-slate-300');
        feedbackLink?.classList.add('text-slate-300');
      } else if (currentPath.startsWith('/forms')) {
        feedbackLink?.classList.add('bg-teal-500/10', 'text-teal-400', 'hover:text-teal-300');
        feedbackLink?.classList.remove('text-slate-300');
        homeLink?.classList.add('text-slate-300');
      }
    </script>
  </body>
</html>
